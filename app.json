{
  "expo": {
    "name": "Shared Living",
    "slug": "shared-living",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "shared-living",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jeevan0714.sharedliving",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jeevan0714.sharedliving",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5218b669-c4a7-4168-a271-6d475681f2b7"
      }
    },
    "owner": "jeevan0714",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5218b669-c4a7-4168-a271-6d475681f2b7"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-audio",
      "expo-font",
      "expo-asset"
    ]
  }
}
