rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is a member of the household
    function isMember(householdId) {
      return request.auth != null && 
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // User Profiles: Any authenticated user can view, but only the owner can modify
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Usernames: Allow checking availability (unauthenticated) and claiming/deleting by the owner
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Households: Members can view, update (to join/leave), and creator can delete
    match /households/{householdId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members || 
        request.auth.uid in request.resource.data.members
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      // All subcollections (expenses, chores, groceries, messages, activities) require membership
      match /{allSubcollections=**} {
        allow read, write: if isMember(householdId);
      }
    }

    // Crash reports: Write-only for authenticated users, read-disabled on the client
    match /crashes/{crashId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Invitations: Authenticated users can read/create/update invitations under strict conditions
    match /invitations/{invitationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
        (resource.data.status == 'pending' && request.resource.data.status == 'expired') ||
        (resource.data.status == 'pending' && 
         request.resource.data.status == 'accepted' && 
         request.resource.data.usedBy == request.auth.uid)
      );
    }
  }
}
